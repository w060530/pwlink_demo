{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "cortex-debug",
            "request": "launch",
            "name": "PWLINK: pyOCD Debug (自动)",
            "servertype": "external",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/${workspaceFolderBasename}.elf",
            "device": "STM32F103RC",
            "gdbTarget": "localhost:50000",
            "runToEntryPoint": "main",
            "preLaunchTask": "启动 pyOCD GDB Server",
            "showDevDebugOutput": "none"
        },
        {
            "type": "cortex-debug",
            "request": "launch",
            "name": "PWLINK: pyOCD Debug (手动)",
            "servertype": "external",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/${workspaceFolderBasename}.elf",
            "device": "STM32F103RC",
            "gdbTarget": "localhost:50000",
            "runToEntryPoint": "main"
        }
    ]
}
